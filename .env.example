# Leave empty for local dev — the app uses the Vite proxy to reach the API on port 8787.
# Only set this if the API runs on another host/port.
VITE_API_BASE_URL=

# From Supabase: Project Settings → API (required for email + Google login)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
#
# Supabase Dashboard → Authentication → Providers: enable Email; enable Google (OAuth client ID/secret).
# Authentication → URL Configuration:
#   Site URL: http://localhost:5173 (or your deployed origin)
#   Redirect URLs: add http://localhost:5173/auth/callback (and production URL + /auth/callback)

# API server only — do NOT use VITE_ prefix (keeps the key off the browser).
# Required for POST /api/chat and career tips. Restart `npm run dev` after changing.
#
# --- Free testing (recommended to start): Groq — https://console.groq.com/keys
# Leave OPENAI_API_KEY empty and set:
GROQ_API_KEY=
# Optional — defaults to Groq’s OpenAI-compatible base if unset
# GROQ_BASE_URL=https://api.groq.com/openai/v1
# Optional — defaults to llama-3.3-70b-versatile if unset
# GROQ_MODEL=llama-3.3-70b-versatile
#
# --- Production / OpenAI: if OPENAI_API_KEY is set, it wins (Groq vars ignored).
OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini
# OPENAI_BASE_URL=https://api.openai.com/v1

# API server — approve/reject community homepage photos at /admin/hero-photos (send as X-Admin-Token on requests).
# ECOVERSE_ADMIN_TOKEN=your-long-random-secret
